[Unit]
Description=CrewPlay Mitake SMS Proxy
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/crewplay-sms-proxy
EnvironmentFile=/opt/crewplay-sms-proxy/.env
ExecStart=/usr/bin/node /opt/crewplay-sms-proxy/server.mjs
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target

# Supabase (optional — without these, site reads public/data/teams.json)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LINE Login (Phase 2)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LINE_LIFF_ID=

# Apple Sign In（需在 Apple Developer 建立 Services ID 與 Key）
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# 私鑰內容，換行以 \n 表示
APPLE_PRIVATE_KEY=

# 手機驗證碼簡訊（正式上線請設定 Mitake 三竹，或 Twilio）
# 供應商：mitake | twilio | auto（預設 auto = 先 Mitake 再 Twilio）
SMS_PROVIDER=mitake
SMS_BRAND_NAME=CrewPlay

# 三竹 Mitake（台灣常用，https://sms.mitake.com.tw）
# Netlify 無固定 IP：Mitake 帳密放 VPS，Netlify 只填 proxy 網址
MITAKE_PROXY_URL=
SMS_PROXY_SECRET=
MITAKE_USERNAME=
MITAKE_PASSWORD=
# MITAKE_API_URL=https://smsapi.mitake.com.tw/api/mtk/SmSend?CharsetURL=UTF-8

# Twilio（備用）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# 開發環境才顯示畫面驗證碼；正式站請設 false 或移除
AUTH_DEV_OTP=true

# ECPay（測試環境預設為綠界 Stage 測試商店；上線請改 production）
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_ENV=test
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin
ADMIN_API_KEY=

# Gmail（開團／場地表單通知與客戶回覆）
# 請至 Google 帳戶 → 安全性 → 兩步驟驗證 → 應用程式密碼，產生 16 碼密碼
GMAIL_USER=crew.matchplay@gmail.com
GMAIL_APP_PASSWORD=
# 收到新報名／表單通知的您的信箱（可填多組，逗號分隔）
GMAIL_NOTIFY_TO=jak85710@gmail.com

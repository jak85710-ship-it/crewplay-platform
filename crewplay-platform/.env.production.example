# 正式站環境變數範本 → 複製到 Netlify Environment variables
# 網域：https://www.crewplay.tw

NEXT_PUBLIC_SITE_URL=https://www.crewplay.tw

# 資料來源（未接 Supabase 時使用 public/data/teams.json）
TEAMS_DATA_SOURCE=json

# LINE Login + LIFF（LINE Developers 後台 Callback 需含下方網址）
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LINE_LIFF_ID=

# Apple Sign In（選填）
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# 手機 OTP 簡訊（三竹 Mitake 需固定 IP — Netlify 請走 VPS 閘道）
SMS_PROVIDER=mitake
SMS_BRAND_NAME=CrewPlay
# Netlify 只填下面兩行；Mitake 帳密放在 VPS 的 sms-proxy/.env
MITAKE_PROXY_URL=https://YOUR_VPS_IP:8787/api/sms/login-otp
SMS_PROXY_SECRET=choose-a-long-random-secret
AUTH_DEV_OTP=false

# 若主機有固定 IP、可直接打 Mitake，才在 Netlify 填（一般不用）
# MITAKE_USERNAME=
# MITAKE_PASSWORD=

# 綠界 ECPay（正式環境請改 production）
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_ENV=production

# Gmail 表單通知
GMAIL_USER=crew.matchplay@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_NOTIFY_TO=crew.matchplay@gmail.com

# 管理後台 API（選填）
ADMIN_API_KEY=

# Supabase（選填，長期建議接上）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 正式站環境變數範本 → 複製到 Netlify Environment variables
# 網域：https://www.crewplay.tw

NEXT_PUBLIC_SITE_URL=https://www.crewplay.tw

# Google Ads 轉換追蹤（gtag.js）
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-18275446861
# Google Analytics 4 漏斗分析（必填才能看「在哪一步流失」）
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# 本地流量儀表板匯出（匯出流量數據.bat 用）+ 保護 /api/analytics/export
ADMIN_API_KEY=請設一組長隨機字串

# 資料來源（未接 Supabase 時使用 public/data/teams.json）
TEAMS_DATA_SOURCE=json

# LINE Login + LIFF（LINE Developers 後台 Callback 需含下方網址）
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LINE_LIFF_ID=
# LINE 推播通知（先灰度開啟，確認正常後再全量）
LINE_NOTIFY_ENABLED=false
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# 團主通知收件者（可填多組 userId/groupId，逗號分隔）
LINE_NOTIFY_HOST_UIDS=
# 依 team_id 指定收件者（JSON），例如 {"team-1":["Uxxxx"],"team-2":"Cxxxx"}
LINE_NOTIFY_HOST_UIDS_BY_TEAM=

# Apple Sign In（選填）
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# 手機 OTP 簡訊（三竹 Mitake 需固定 IP — Netlify 請走 VPS 閘道）
SMS_PROVIDER=mitake
SMS_BRAND_NAME=CrewPlay
# Netlify 只填下面兩行；Mitake 帳密放在 VPS 的 sms-proxy/.env
MITAKE_PROXY_URL=https://YOUR_VPS_IP:8787/api/sms/login-otp
SMS_PROXY_SECRET=choose-a-long-random-secret
AUTH_DEV_OTP=false

# 若主機有固定 IP、可直接打 Mitake，才在 Netlify 填（一般不用）
# MITAKE_USERNAME=
# MITAKE_PASSWORD=
MITAKE_API_URL=https://smsapi.mitake.com.tw/api/mtk/SmSend?CharsetURL=UTF-8
# 三竹伺服器：smsapi.mitake.com.tw (211.72.227.230 / 60.250.14.104 :443)

# 綠界 ECPay（正式環境請改 production）
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_ENV=production

# 團主／場主上架費 — 藍新金流 EPG 付款頁
NEWEBPAY_LISTING_URL=https://core.newebpay.com/EPG/crewplay/srGmIC
NEXT_PUBLIC_NEWEBPAY_LISTING_URL=https://core.newebpay.com/EPG/crewplay/srGmIC

# 團主／場主平台刊登費（NTD，預設 500）
JOIN_HOST_FEE=500
JOIN_VENUE_FEE=500

# Gmail：GMAIL_USER=寄信帳號；GMAIL_NOTIFY_TO=您收通知的信箱
GMAIL_USER=crew.matchplay@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_NOTIFY_TO=crew.matchplay@gmail.com
# 團主通知信箱補強（可選）
# 全域預設備援：多組用逗號
# HOST_NOTIFICATION_EMAILS_GLOBAL=crew.matchplay@gmail.com
# 分團指定（JSON）：{"team-id":"host@example.com","team-id-2":["a@x.com","b@x.com"]}
# HOST_NOTIFICATION_EMAILS_BY_TEAM=
# 可選：自訂 SMTP（例如公司郵件閘道）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Supabase（選填，長期建議接上）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
